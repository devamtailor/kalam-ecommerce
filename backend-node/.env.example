# Environment Variables for Kalam Backend
# Copy this file to .env and fill in the values

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas - Get your connection string from MongoDB Atlas dashboard
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/kalam_shop?retryWrites=true&w=majority

# JWT Secret - Generate a strong random string (min 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials (for initial admin user creation via seed script)
ADMIN_EMAIL=admin@kalambooks.com
ADMIN_PASSWORD=Kalam@2024

# Frontend URL (for CORS - set to your Netlify URL)
FRONTEND_URL=https://your-app.netlify.app
